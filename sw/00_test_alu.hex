// ALU test (00_test_alu)
// Generated with Ripes (https://github.com/mortbopet/Ripes)
// Just some arithmetic instructions

//  addi x1, x0, 5 
//  addi x2, x0, 10 
//  add  x1, x1, x2
//  addi x2, x2, 3 
//  sub  x1, x1, x2 
// _loop:
//  jal  _loop

00500093 // addi x1, x0, 5     -> x1 = 5  (0x05)
00A00113 // addi x2, x0, 10    -> x2 = 10 (0x0A)
002080B3 // add  x1, x1, x2    -> x1 = x1 + x2 = 15 (0x0F)
00310113 // addi x2, x2, 3     -> x2 = x2 + 3 = 13  (0x0D)
402080B3 // sub  x1, x1, x2    -> x1 = x1 - x2 = 2  (0x02)
0000006F // jal  x0, 0         -> endless loop (halt)
